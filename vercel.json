{
  "rewrites": [
    { "source": "/f/:id", "destination": "/api/f/[id].js" },
    { "source": "/api/s", "destination": "/api/upload.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
